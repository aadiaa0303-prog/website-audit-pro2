# ============================================
# Website Audit Pro - Environment Configuration
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Settings
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUDIT_RATE_LIMIT_WINDOW_MS=60000
AUDIT_RATE_LIMIT_MAX_REQUESTS=5

# Data Storage
MAX_STORED_RESULTS=1000

# Logging
LOG_LEVEL=info
